{
  "name": "Aegis Simulation",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  "forwardPorts": [4000, 5432, 8010, 8011, 8012, 8013, 8014],

  "postCreateCommand": "pip install -r requirements.txt && pip install -r incidents/requirements.txt",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker"
      ]
    }
  },

  "remoteEnv": {
    "GROQ_API_KEY": "${localEnv:GROQ_API_KEY}"
  }
}
