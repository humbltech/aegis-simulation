# ============================================
# Aegis Simulation Environment Variables
# ============================================

# Aegis URL (leave empty to bypass Aegis and go direct to LLM)
# AEGIS_URL=http://localhost:8080

# ============================================
# RECOMMENDED: Groq (FREE - no local resources needed!)
# ============================================
# Get free API key in 30 seconds: https://console.groq.com/keys
# Groq runs Llama 3.1 in the cloud - very fast, generous free tier
GROQ_API_KEY=gsk_xxx

# ============================================
# OTHER OPTIONS (if you prefer):
# ============================================

# Ollama (FREE but needs local RAM/disk)
# Only if you have resources: make ollama-setup

# Google Gemini (FREE tier - 15 requests/min)
# Get key: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=xxx

# OpenAI GPT-4o-mini (CHEAP - $0.15/1M tokens)
# OPENAI_API_KEY=sk-xxx

# OPTION 3: Google Gemini (CHEAPEST cloud - $0.075/1M tokens)
# Get free key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=xxx

# OPTION 4: OpenAI GPT-4o-mini (CHEAP - $0.15/1M tokens)
# Good for demos, reliable tool calling
OPENAI_API_KEY=sk-xxx

# OPTION 5: DeepSeek (VERY CHEAP - $0.14/1M tokens)
# Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxx

# OPTION 6: Anthropic (PREMIUM - for customer demos)
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================
# Recommended for local development:
# ============================================
# 1. Ollama (free): make up-ollama
# 2. Groq (free tier): GROQ_API_KEY=gsk_xxx
# 3. GPT-4o-mini (cheap): OPENAI_API_KEY=sk-xxx
